# Backend Environment Configuration
# Copy to .env and customize

# Service Ports
GATEWAY_PORT=8000
OCR_SERVICE_PORT=8001
DRUG_EXTRACTOR_PORT=8002
DRUG_INFO_SERVICE_PORT=8003
AUDIT_SERVICE_PORT=8004

# Service URLs (for Docker use service names instead of localhost)
OCR_SERVICE_URL=http://localhost:8001
DRUG_EXTRACTOR_URL=http://localhost:8002
DRUG_INFO_SERVICE_URL=http://localhost:8003
AUDIT_SERVICE_URL=http://localhost:8004

# LM Studio Configuration
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_CHAT_MODEL=google/gemma-4-e2b
LMSTUDIO_TIMEOUT=120
LMSTUDIO_TEMPERATURE=0.2

# OCR Configuration
OCR_USE_GPU=false

# File Upload
MAX_FILE_SIZE_MB=10

# Retention (hours)
IMAGE_RETENTION_HOURS=24
LOG_RETENTION_HOURS=168
